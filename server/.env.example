# ── Database ──────────────────────────────────────────────
# Local MySQL — update host/port/user/password to match your setup
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=InventoryAssist

# ── Auth ──────────────────────────────────────────────────
# Any long random string works for local development
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Stripe (post-launch only — leave as-is for local dev) ─
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
